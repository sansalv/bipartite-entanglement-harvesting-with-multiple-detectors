Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", 
    RowBox[{"P", ",", "Xr", ",", "Xl", ",", "Cx", ",", "\[Alpha]", ",", "y"}],
     "]"}], ";"}], "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{"Define", " ", 
    FormBox[
     TemplateBox[<|"boxes" -> FormBox[
         SubscriptBox[
          OverscriptBox["\[Rho]", "~"], "1"], TraditionalForm], 
       "errors" -> {}, "input" -> "\\tilde\\rho_1", "state" -> "Boxes"|>,
      "TeXAssistantTemplate"],
     TraditionalForm], " ", "block"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"M3", "=", 
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"P", ",", 
        RowBox[{"Conjugate", "[", "Xr", "]"}], ",", 
        RowBox[{"Conjugate", "[", "Xl", "]"}]}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"Xr", ",", "P", ",", 
        RowBox[{"Conjugate", "[", "Cx", "]"}]}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"Xl", ",", "Cx", ",", "P"}], "}"}]}], "\[IndentingNewLine]", 
     "}"}]}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"characteristicEquation", "=", 
   RowBox[{
    RowBox[{"Det", "[", 
     RowBox[{"M3", "-", 
      RowBox[{"\[Alpha]", " ", 
       RowBox[{"IdentityMatrix", "[", "3", "]"}]}]}], "]"}], "==", "0"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"depressedCubic", "=", 
    RowBox[{
     RowBox[{
      RowBox[{"characteristicEquation", "/.", " ", 
       RowBox[{"\[Alpha]", "->", 
        RowBox[{"y", "+", "P"}]}]}], "//", "Expand"}], " ", "//", 
     RowBox[{"ReplaceRepeated", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"z_", "*", 
         RowBox[{"Conjugate", "[", "z_", "]"}]}], ":>", 
        RowBox[{
         RowBox[{"Abs", "[", "z", "]"}], "^", "2"}]}], "}"}], "]"}]}]}], " ", 
   
   RowBox[{"(*", 
    RowBox[{
    "Simplify", " ", "the", " ", "equation", " ", "by", " ", "shifting"}], 
    "*)"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Define", " ", "parameters", " ", "for", " ", "the", " ", "root", " ", 
    "solutions"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"S", "=", 
   RowBox[{"Sqrt", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Abs", "[", "Cx", "]"}], "^", "2"}], "+", 
     RowBox[{
      RowBox[{"Abs", "[", "Xr", "]"}], "^", "2"}], "+", 
     RowBox[{
      RowBox[{"Abs", "[", "Xl", "]"}], "^", "2"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"R", "=", 
   RowBox[{
    RowBox[{"1", "/", "2"}], 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Cx", " ", "Xr", " ", 
       RowBox[{"Conjugate", "[", "Xl", "]"}]}], "+", 
      RowBox[{
       RowBox[{"Conjugate", "[", "Cx", "]"}], 
       RowBox[{"Conjugate", "[", "Xr", "]"}], " ", "Xl"}]}], ")"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"rho", "=", 
   RowBox[{
    RowBox[{"Sqrt", "[", 
     RowBox[{"4", "/", "3"}], "]"}], " ", "S"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"phi", "=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "/", "3"}], ")"}], " ", 
     RowBox[{"ArcCos", "[", 
      RowBox[{"3", " ", 
       RowBox[{"Sqrt", "[", "3", "]"}], " ", 
       RowBox[{"R", "/", 
        RowBox[{"S", "^", "3"}]}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"\"\<Guess\>\"", " ", "the", " ", "roots"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"yRoots", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"rho", " ", 
       RowBox[{"Cos", "[", 
        RowBox[{"phi", "+", 
         RowBox[{"2", " ", "Pi", " ", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"k", "-", "1"}], ")"}], "/", "3"}]}]}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "1", ",", "3"}], "}"}]}], "]"}]}], ";"}], "\n", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Verify", " ", "the", " ", "roots", " ", "against", " ", "the", " ", 
    "polynomial"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"Table", "[", 
  RowBox[{
   RowBox[{"Simplify", "[", 
    RowBox[{"depressedCubic", "/.", " ", 
     RowBox[{"y", "->", "yRoot"}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"yRoot", ",", "yRoots"}], "}"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.964145158348466*^9, 3.964145194518436*^9}, {
   3.964145616617629*^9, 3.9641456171927357`*^9}, {3.9641457594969788`*^9, 
