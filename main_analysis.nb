        RowBox[{"DawsonF", "[", 
         FractionBox["\[CapitalDelta]x", 
          RowBox[{"2", " ", "\[Sigma]"}]], "]"}]}], 
       RowBox[{"4", " ", 
        SuperscriptBox["\[Pi]", "2"], " ", "\[CapitalDelta]x", " ", 
