 InterpretationBox[
  RowBox[{"\<\"Neg(2 detectors) = \"\>", "\[InvisibleSpace]", 
   RowBox[{
    RowBox[{"Abs", "[", 
     RowBox[{
      FractionBox[
       RowBox[{"\[ImaginaryI]", " ", 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"-", 
          FractionBox[
           RowBox[{
            SuperscriptBox["\[CapitalDelta]x", "2"], "+", 
            RowBox[{"4", " ", 
             SuperscriptBox["\[Sigma]", "4"], " ", 
             SuperscriptBox["\[CapitalOmega]", "2"]}]}], 
