   3.9785925161207438`*^9}},ExpressionUUID->"793e2c7a-d4cd-4f37-a9e7-\
b166bf0bc8e8"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"tildeRho1Asymm4", "[", 
    RowBox[{"P_", ",", "Xl_", ",", "C32_", ",", "C21_", ",", "C31_"}], "]"}], 
   ":=", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"P", ",", 
       RowBox[{"Conjugate", "[", "Xl", "]"}], ",", 
       RowBox[{"Conjugate", "[", "Xl", "]"}], ",", 
       RowBox[{"Conjugate", "[", "Xl", "]"}]}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"Xl", ",", "P", ",", "C32", ",", "C31"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"Xl", ",", "C32", ",", "P", ",", "C21"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"Xl", ",", "C31", ",", "C21", ",", "P"}], "}"}]}], 
    "\[IndentingNewLine]", "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"neg4Asymm", "[", 
   RowBox[{"\[CapitalOmega]_", ",", "\[Theta]21_", ",", "\[Theta]32_", ",", 
    RowBox[{"l_", ":", "L1"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "P", ",", "x32", ",", "x31", ",", "x21", ",", "C32", ",", "C31", ",", 
      "C21", ",", "Xl", ",", "neg"}], "}"}], ",", "\[IndentingNewLine]", 
    "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
     "Compute", " ", "the", " ", "separations", " ", "between", " ", "the", 
      " ", "detectors"}], "*)"}], "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"x21", "=", 
      RowBox[{"2", "l", " ", 
       RowBox[{"Sin", "[", 
        RowBox[{"\[Theta]21", "/", "2"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"x32", "=", 
      RowBox[{"2", "l", " ", 
       RowBox[{"Sin", "[", 
        RowBox[{"\[Theta]32", "/", "2"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"x31", "=", 
      RowBox[{"2", "l", " ", 
       RowBox[{"Sin", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"2", "Pi"}], "-", "\[Theta]21", "-", "\[Theta]32"}], ")"}],
          "/", "2"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"Compute", " ", "the", " ", "matrix", " ", "components"}], ",",
        " ", 
       RowBox[{
        RowBox[{"note", ":", " ", "P"}], "=", "L_ii"}], ",", " ", 
       RowBox[{"C_ij", "=", 
        RowBox[{
         RowBox[{"L_ij", " ", "and", " ", "X_ij"}], "=", "M_ij"}]}]}], "*)"}],
      "\[IndentingNewLine]", 
     RowBox[{"P", "=", 
      RowBox[{"Pii", "[", "\[CapitalOmega]", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Xl", "=", 
      RowBox[{"Xij", "[", 
       RowBox[{"l", ",", "\[CapitalOmega]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"C21", "=", 
      RowBox[{"Cij", "[", 
       RowBox[{"x21", ",", "\[CapitalOmega]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"C32", "=", 
      RowBox[{"Cij", "[", 
       RowBox[{"x32", ",", "\[CapitalOmega]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"C31", "=", 
      RowBox[{"Cij", "[", 
       RowBox[{"x31", ",", "\[CapitalOmega]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"neg", "=", 
      RowBox[{"-", 
       RowBox[{"Total", "[", 
        RowBox[{"Select", "[", 
         RowBox[{
          RowBox[{"Eigenvalues", "[", 
           RowBox[{"tildeRho1Asymm4", "[", 
            RowBox[{"P", ",", "Xl", ",", "C32", ",", "C21", ",", "C31"}], 
            "]"}], "]"}], ",", 
          RowBox[{
           RowBox[{"#", "<", "0"}], "&"}]}], "]"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", "neg"}]}], "\[IndentingNewLine]", 
   "]"}]}]}], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.961741924058876*^9, 3.961741981273416*^9}, 
