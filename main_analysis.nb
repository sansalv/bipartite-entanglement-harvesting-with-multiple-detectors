         RowBox[{"3", "/", "2"}]], " ", "\[CapitalDelta]x", " ", 
        "\[Sigma]"}]], "-", 
      FractionBox[
       RowBox[{
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{
          RowBox[{"-", 
           SuperscriptBox["\[Sigma]", "2"]}], " ", 
