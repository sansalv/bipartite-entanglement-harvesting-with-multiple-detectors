Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
      "===", "===", "===", "===", "===", "===", "===", "===", "===", "==="}], 
    "="}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"USER", " ", "SETUP", " ", 
     RowBox[{"BEGINS", ":", " ", 
      RowBox[{"define", " ", "numerical", " ", "constants"}]}]}], ",", " ", 
    RowBox[{"smearing", " ", "and", " ", "switching"}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"prec", "=", "30"}], " ", 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{
      "Working", " ", "precision", " ", "for", " ", "all", " ", "numerical", 
       " ", "computations"}], ";", " ", 
      RowBox[{"30", " ", "is", " ", "enough"}]}], "*)"}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Rt1", "=", 
      RowBox[{"SetPrecision", "[", 
       RowBox[{
        RowBox[{"1", "/", "100"}], ",", "prec"}], "]"}]}], ";"}], 
    RowBox[{"(*", 
     RowBox[{"Half", "-", 
      RowBox[{
      "width", " ", "of", " ", "the", " ", "interaction", " ", "time", " ", 
       "window", " ", 
       RowBox[{"(", 
        RowBox[{"also", " ", "denoted", " ", "T"}], ")"}]}]}], "*)"}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Rs1", "=", 
      RowBox[{"Rt1", "/", "20"}]}], 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"Detector", " ", "spatial", " ", "size"}], ";", " ", 
       RowBox[{
        RowBox[{"only", " ", "required", " ", "for", " ", "non"}], "-", 
        RowBox[{"pointlike", " ", "detectors"}]}]}], "*)"}], ";"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Alpha]1", "=", "5"}], 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{
      "Dimensionless", " ", "scale", " ", "factor", " ", "controlling", " ", 
       "approximate", " ", "compact", " ", "support", " ", "in", " ", "non"}],
       "-", 
      RowBox[{
      "compact", " ", "support", " ", "cases", " ", "such", " ", "as", " ", 
       "Gaussian"}]}], "*)"}], ";"}], " ", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"smearingMom", "[", "k_", "]"}], ":=", "1"}], 
    RowBox[{"(*", 
     RowBox[{"some", " ", 
      RowBox[{"options", ":", " ", 
       RowBox[{
        RowBox[{"smearingFuncMomCSGeneral", "[", 
         RowBox[{"k", ",", "Rs1", ",", "3"}], "]"}], " ", "or", " ", 
        RowBox[{"sFuncMomGaussian", "[", 
         RowBox[{"k", ",", " ", 
          RowBox[{"Rs1", "/", "\[Alpha]1"}]}], "]"}], " ", "or", " ", "1", 
        " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"if", " ", "point"}], "-", "like"}], ")"}]}]}]}], "*)"}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"switchingMom", "[", "\[Omega]_", "]"}], ":=", 
     RowBox[{"sFuncMomGaussian", "[", 
      RowBox[{"\[Omega]", ",", 
       RowBox[{"Rt1", "/", "\[Alpha]1"}]}], "]"}]}], 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{"some", " ", 
       RowBox[{"options", ":", " ", 
        RowBox[{"sFuncMomGaussian", "[", 
         RowBox[{"\[Omega]", ",", 
          RowBox[{"Rt1", "/", "\[Alpha]1"}]}], "]"}]}]}], ",", " ", 
      RowBox[{"switchingMomGaussianTruncated", "[", 
       RowBox[{"\[Omega]", ",", 
        RowBox[{"Rt1", "/", "\[Alpha]1"}], ",", "Rt1"}], "]"}], ",", " ", 
      RowBox[{
       RowBox[{"switchingMomCompactifiedPolynomial", "[", 
        RowBox[{"\[Omega]", ",", "Rt1", ",", "9.4"}], "]"}], " ", "or", " ", 
       "1", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"if", " ", "point"}], "-", "like"}], ")"}]}]}], "*)"}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"USER", " ", "SETUP", " ", "ENDS"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
       "===", "===", "===", "===", "===", "===", "===", "===", "===", "==="}],
      "="}], "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Define", " ", "configuration", " ", "flags", " ", "and", " ", 
     "numerical", " ", "parameters"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"isPointlikeDetectors", "=", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"smearingMom", "[", 
        RowBox[{"1.5", "Rt1"}], "]"}], " ", "==", " ", "1"}], ")"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"isGaussianSwitching", "=", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"switchingMom", "[", 
        RowBox[{"1.5", "Rt1"}], "]"}], "==", 
       RowBox[{"Simplify", "[", 
        RowBox[{"sFuncMomGaussian", "[", 
         RowBox[{
          RowBox[{"1.5", "Rt1"}], ",", " ", 
          RowBox[{"Rt1", "/", "\[Alpha]1"}]}], "]"}], "]"}]}], ")"}]}], ";"}],
    "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"!", "isPointlikeDetectors"}], "&&", 
       RowBox[{"!", 
        RowBox[{"NumericQ", "[", "Rs1", "]"}]}]}], ",", 
      RowBox[{
       RowBox[{
       "MessageDialog", "[", 
        "\"\<Error: Rs1 must be defined as a numerical value when not using \
pointlike detectors.\>\"", "]"}], ";", 
       RowBox[{"Abort", "[", "]"}]}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"\[CapitalDelta]T", "=", 
     RowBox[{"2", "Rt1"}]}], " ", 
    RowBox[{"(*", 
     RowBox[{"Total", " ", "interaction", " ", "time", " ", "window"}], 
     "*)"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"L1", "=", 
     RowBox[{"If", "[", 
      RowBox[{"isPointlikeDetectors", ",", " ", "\[CapitalDelta]T", ",", 
       RowBox[{
        RowBox[{"2", " ", "Rs1"}], "+", "\[CapitalDelta]T"}]}], "]"}]}], 
    RowBox[{"(*", 
     RowBox[{"Minimal", " ", "causal", " ", "separation", " ", "l"}], "*)"}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"kmin1", "=", "0"}], 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{"Numerical", " ", "integration", " ", "minimum"}], ";", " ", 
