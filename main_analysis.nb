Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"print3DetectorInfo", "[", 
    RowBox[{"r_", ",", "\[Theta]_", ",", "\[CapitalOmega]_", ",", 
     RowBox[{"l_", ":", "L1"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "P", ",", "Cx", ",", "CxPlus", ",", "CxMinus", ",", "Xl", ",", "Xr", 
       ",", "x", ",", "S", ",", "R", ",", "\[Rho]", ",", "\[Phi]", ",", 
       "eigenvals", ",", "negativity"}], "}"}], ",", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"P", "=", 
       RowBox[{"Pii", "[", "\[CapitalOmega]", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Xl", "=", 
       RowBox[{"Xij", "[", 
        RowBox[{"l", ",", "\[CapitalOmega]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Xr", "=", 
       RowBox[{"Xij", "[", 
        RowBox[{"r", ",", "\[CapitalOmega]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"x", "=", 
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{"r", "^", "2"}], "+", 
         RowBox[{"l", "^", "2"}], "-", 
         RowBox[{"2", "r", " ", "l", " ", 
          RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Cx", "=", 
       RowBox[{"Cij", "[", 
        RowBox[{"x", ",", "\[CapitalOmega]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"CxPlus", "=", 
       RowBox[{"CijPlus", "[", 
        RowBox[{"x", ",", "\[CapitalOmega]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"CxMinus", "=", 
       RowBox[{"CijMinus", "[", 
        RowBox[{"x", ",", "\[CapitalOmega]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"S", "=", 
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Abs", "[", "Cx", "]"}], "^", "2"}], "+", 
         RowBox[{
          RowBox[{"Abs", "[", "Xr", "]"}], "^", "2"}], "+", 
         RowBox[{
          RowBox[{"Abs", "[", "Xl", "]"}], "^", "2"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"R", "=", 
       RowBox[{"Re", "[", 
        RowBox[{"Cx", " ", "Xr", " ", 
         RowBox[{"Conjugate", "[", "Xl", "]"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"\[Rho]", "=", 
       RowBox[{
        RowBox[{"Sqrt", "[", 
         RowBox[{"4", "/", "3"}], "]"}], "S"}]}], ";", "\[IndentingNewLine]", 
      
      RowBox[{"\[Phi]", "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "/", "3"}], ")"}], " ", 
        RowBox[{"ArcCos", "[", 
         RowBox[{"3", " ", 
          RowBox[{"Sqrt", "[", "3", "]"}], " ", 
          RowBox[{"R", "/", 
           RowBox[{"S", "^", "3"}]}]}], "]"}]}]}], ";", "\[IndentingNewLine]",
       "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<Analytical results with r/l=\>\"", ",", 
        RowBox[{"r", "/", "l"}], ",", "\"\<, \[Theta]=\>\"", ",", "\[Theta]", 
        ",", "\"\<, \[CapitalOmega]=\>\"", ",", "\[CapitalOmega]", ",", 
        "\"\<:\>\""}], "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<x/l = \>\"", ",", " ", 
        RowBox[{"x", "/", "l"}]}], "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<P = \>\"", ",", " ", "P"}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<C = \>\"", ",", " ", "Cx"}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<C+ = \>\"", ",", " ", "CxPlus"}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<C- = \>\"", ",", " ", "CxMinus"}], "]"}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"Print", "[", "\"\<\>\"", "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<X^2 < P/2(P+C) : \>\"", ",", " ", 
        RowBox[{
         RowBox[{
          RowBox[{"Abs", "[", "Xl", "]"}], "^", "2"}], " ", "<", " ", 
         RowBox[{
          RowBox[{"P", "/", "2"}], 
          RowBox[{"(", 
           RowBox[{"P", "+", "Cx"}], ")"}]}]}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<X^2 > P^2/3(1+2C/P) : \>\"", ",", " ", 
        RowBox[{
         RowBox[{
          RowBox[{"Abs", "[", "Xl", "]"}], "^", "2"}], " ", ">", " ", 
         RowBox[{
          RowBox[{
           RowBox[{"P", "^", "2"}], "/", "3"}], 
          RowBox[{"(", 
           RowBox[{"1", "+", 
            RowBox[{"2", 
             RowBox[{"Cx", "/", "P"}]}]}], ")"}]}]}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<X^2 > P^2/4 : \>\"", ",", "  ", 
        RowBox[{
         RowBox[{
          RowBox[{"Abs", "[", "Xl", "]"}], "^", "2"}], ">", 
         RowBox[{
          RowBox[{"P", "^", "2"}], "/", "4"}]}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Print", "[", "\"\<\>\"", "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<\[Rho]/P = \>\"", ",", " ", 
        RowBox[{"\[Rho]", "/", "P"}]}], "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<\[Phi] = \>\"", ",", 
        RowBox[{"\[Phi]", "/", "Pi"}], ",", "\"\<\[Pi] = \[Pi]/\>\"", ",", 
        RowBox[{"Pi", "/", "\[Phi]"}]}], "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<Cos(\[Phi]1) = \>\"", ",", " ", 
        RowBox[{"Cos", "[", "\[Phi]", "]"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<Cos(\[Phi]2) = \>\"", ",", " ", 
        RowBox[{"Cos", "[", 
         RowBox[{"\[Phi]", "+", 
          RowBox[{"2", 
           RowBox[{"Pi", "/", "3"}]}]}], "]"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<Cos(\[Phi]3) = \>\"", ",", " ", 
        RowBox[{"Cos", "[", 
         RowBox[{"\[Phi]", "+", 
          RowBox[{"4", 
           RowBox[{"Pi", "/", "3"}]}]}], "]"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<\[Alpha]1 = \>\"", ",", " ", 
        RowBox[{"P", "+", 
         RowBox[{"\[Rho]", " ", 
          RowBox[{"Cos", "[", "\[Phi]", "]"}]}]}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<\[Alpha]2 = \>\"", ",", " ", 
        RowBox[{"P", "+", 
         RowBox[{"\[Rho]", " ", 
          RowBox[{"Cos", "[", 
           RowBox[{"\[Phi]", "+", 
            RowBox[{"2", " ", "Pi", " ", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"2", "-", "1"}], ")"}], "/", "3"}]}]}], "]"}]}]}]}], 
       "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<\[Alpha]3 = \>\"", ",", " ", 
        RowBox[{"P", "+", 
         RowBox[{"\[Rho]", " ", 
          RowBox[{"Cos", "[", 
           RowBox[{"\[Phi]", "+", 
            RowBox[{"2", " ", "Pi", " ", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"3", "-", "1"}], ")"}], "/", "3"}]}]}], "]"}]}]}]}], 
       "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"eigenvals", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"P", "+", 
          RowBox[{"\[Rho]", " ", 
           RowBox[{"Cos", "[", 
            RowBox[{"\[Phi]", "+", 
             RowBox[{"2", " ", "Pi", " ", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"k", "-", "1"}], ")"}], "/", "3"}]}]}], "]"}]}]}], 
         ",", 
         RowBox[{"{", 
          RowBox[{"k", ",", "1", ",", "3"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"negativity", "=", 
       RowBox[{"Total", "[", 
        RowBox[{"-", 
         RowBox[{"Select", "[", 
          RowBox[{"eigenvals", ",", 
           RowBox[{
            RowBox[{"#", "<", "0"}], "&"}]}], "]"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<LO negativity = \>\"", ",", "negativity"}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Print", "[", "\"\<--------------------------\>\"", "]"}], ";", 
      "\[IndentingNewLine]", "negativity"}]}], "\[IndentingNewLine]", "]"}]}],
   ";"}]], "Input",
 InitializationCell->True,
