Cell[BoxData[
 RowBox[{
  RowBox[{"plotXOmegaContourPlot", "[", 
   RowBox[{"dataTable_", ",", 
    RowBox[{"xLabel_", ":", "\"\<x\>\""}], ",", 
    RowBox[{"zLabel_", ":", "\"\<\\\\mathcal{N}^{(2)}\>\""}], ",", 
    RowBox[{"contourVals_", ":", 
     RowBox[{"Range", "[", 
      RowBox[{
       RowBox[{"-", "18"}], ",", "18", ",", "2"}], "]"}]}], ",", 
    RowBox[{"threshold_", ":", "1*^-14"}], ",", 
    RowBox[{"shouldExport_", ":", "False"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "minVal", ",", "maxVal", ",", "zeroPlane", ",", "plot3D", ",", 
      "plotContour", ",", "yMin", ",", "yMax"}], "}"}], ",", 
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"minVal", "=", 
      RowBox[{"Min", "[", 
       RowBox[{"dataTable", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", "3"}], "]"}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"maxVal", "=", 
      RowBox[{"Max", "[", 
       RowBox[{"dataTable", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", "3"}], "]"}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"yMin", "=", 
      RowBox[{"Min", "[", 
       RowBox[{"dataTable", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", "2"}], "]"}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"yMax", "=", 
      RowBox[{"Max", "[", 
       RowBox[{"dataTable", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", "2"}], "]"}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"plotContour", "=", 
      RowBox[{"ListContourPlot", "[", "\[IndentingNewLine]", 
       RowBox[{"dataTable", ",", "\[IndentingNewLine]", 
        RowBox[{"InterpolationOrder", "->", "2"}], ",", "\[IndentingNewLine]", 
        RowBox[{"Contours", "->", "contourVals"}], ",", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{"ContourLabels", "->", 
           RowBox[{"(", 
            RowBox[{"Function", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"z", ",", "xy"}], "}"}], ",", 
              RowBox[{"Text", "[", 
               RowBox[{
                RowBox[{"Style", "[", 
                 RowBox[{
                  RowBox[{"NumberForm", "[", 
                   RowBox[{"z", ",", 
                    RowBox[{"{", 
                    RowBox[{"4", ",", "2"}], "}"}]}], "]"}], ",", 
                  RowBox[{"FontSize", "->", "10"}], ",", "Bold", ",", 
                  RowBox[{"Background", "->", "White"}]}], "]"}], ",", "xy"}],
                "]"}]}], "]"}], ")"}]}], ","}], "*)"}], "\[IndentingNewLine]", 
        RowBox[{"FrameLabel", "->", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"MaTeX", "[", 
            RowBox[{
             RowBox[{"StringTemplate", "[", "\"\<``/L\>\"", "]"}], "[", 
             "xLabel", "]"}], "]"}], ",", 
           RowBox[{"MaTeX", "[", "\"\<\\\\Omega T\>\"", "]"}]}], "}"}]}], ",",
         "\[IndentingNewLine]", 
        RowBox[{"PlotLegends", "->", 
         RowBox[{"BarLegend", "[", 
          RowBox[{"Automatic", ",", 
           RowBox[{"LegendLabel", "->", 
            RowBox[{"Placed", "[", 
             RowBox[{
              RowBox[{"MaTeX", "[", "zLabel", "]"}], ",", "Above"}], 
             "]"}]}]}], "]"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"PlotRange", "->", 
         RowBox[{"{", 
          RowBox[{"All", ",", "All", ",", "All"}], "}"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"AspectRatio", "->", "0.7"}], ",", "\[IndentingNewLine]", 
        RowBox[{"ColorFunction", "->", 
         RowBox[{"Function", "[", 
          RowBox[{"z", ",", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"z", "<=", "threshold"}], ",", "Gray", ",", 
             RowBox[{
              RowBox[{"ColorData", "[", "\"\<Rainbow\>\"", "]"}], "[", 
              RowBox[{"Rescale", "[", 
               RowBox[{"z", ",", 
                RowBox[{"{", 
                 RowBox[{"minVal", ",", "maxVal"}], "}"}]}], "]"}], "]"}]}], 
            "]"}]}], "]"}]}], ",", "\[IndentingNewLine]", 
