Cell[TextData[{
 "Plot  LO negativity in specific energy gap values ",
 StyleBox["wrt \[Theta] angles",
  FontWeight->"Bold"]
}], "Subsection",
 CellChangeTimes->{{3.961741924058876*^9, 3.961741981273416*^9}, 
   3.968395461974922*^9, {3.978513371690969*^9, 3.978513376865759*^9}, {
