   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Define", " ", "the", " ", "integrands", " ", "of", " ", "the", " ", 
     "reduced", " ", "density", " ", "matrix", " ", "components"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"PiiIntegrand", "[", 
      RowBox[{"k_", ",", "\[CapitalOmega]_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"k", "/", 
       RowBox[{"(", 
        RowBox[{"4", " ", 
         RowBox[{"\[Pi]", "^", "2"}]}], ")"}]}], " ", 
      RowBox[{
       RowBox[{"Abs", "[", 
        RowBox[{"smearingMom", "[", "k", "]"}], "]"}], "^", "2"}], " ", 
      RowBox[{
       RowBox[{"Abs", "[", 
        RowBox[{"switchingMom", "[", 
         RowBox[{"k", "+", "\[CapitalOmega]"}], "]"}], "]"}], "^", "2"}]}]}], 
    
    RowBox[{"(*", 
     RowBox[{"also", " ", "denoted", " ", "P"}], "*)"}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"CijIntegrand", "[", 
      RowBox[{"k_", ",", "\[CapitalDelta]x_", ",", "\[CapitalOmega]_"}], 
      "]"}], ":=", 
     RowBox[{
      RowBox[{"1", "/", 
       RowBox[{"(", 
        RowBox[{"4", " ", 
         RowBox[{"\[Pi]", "^", "2"}], " ", "\[CapitalDelta]x"}], ")"}]}], "  ", 
      RowBox[{"Sin", "[", 
       RowBox[{"k", " ", "\[CapitalDelta]x"}], "]"}], " ", 
      RowBox[{
       RowBox[{"Abs", "[", 
        RowBox[{"smearingMom", "[", "k", "]"}], "]"}], "^", "2"}], 
      RowBox[{
       RowBox[{"switchingMom", "[", 
        RowBox[{"k", "+", "\[CapitalOmega]"}], "]"}], "^", "2"}]}]}], 
    RowBox[{"(*", 
     RowBox[{"also", " ", "denoted", " ", "C_ij"}], "*)"}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"XijPlusIntegrand", "[", 
