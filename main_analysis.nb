Cell[TextData[{
 "Define the ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        OverscriptBox["\[Rho]", "~"], "1"], TraditionalForm], "errors" -> {}, 
     "input" -> "\\tilde\\rho_1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "4dddb96a-e5f5-4b13-ba76-954d78a0d40a"],
 " block and LO negativity function"
}], "Subsection",
