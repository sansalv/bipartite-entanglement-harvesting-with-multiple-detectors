Cell[BoxData[
 RowBox[{
  RowBox[{"plotGeneral3DetectorPlots", "[", 
   RowBox[{"dataTable_", ",", 
    RowBox[{"plotRange_", ":", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "4"}], ",", "4"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "4"}], ",", "4"}], "}"}], ",", "All"}], "}"}]}], ",", 
    RowBox[{"contourCount_", ":", "14"}], ",", 
    RowBox[{"threshold_", ":", "1*^-14"}], ",", 
    RowBox[{"shouldExport_", ":", "False"}], ",", " ", 
    RowBox[{"shouldPlotOnlyDensity_", ":", "False"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "dataCartesian", ",", "dataUpper", ",", "dataLower", ",", "dataFull", 
      ",", "minVal", ",", "maxVal", ",", "zeroPlane", ",", "plot2D", ",", 
      "plot3D", ",", "plotContour"}], "}"}], ",", "\[IndentingNewLine]", 
    "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
     "Convert", " ", "polar", " ", "coordinates", " ", "to", " ", 
      "Cartesian"}], "*)"}], "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"dataCartesian", "=", 
      RowBox[{"dataTable", "/.", " ", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"r_", ",", "thetaPi_", ",", "val_"}], "}"}], ":>", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"r", " ", 
           RowBox[{"Cos", "[", 
            RowBox[{"thetaPi", " ", "Pi"}], "]"}]}], ",", 
          RowBox[{"r", " ", 
           RowBox[{"Sin", "[", 
            RowBox[{"thetaPi", " ", "Pi"}], "]"}]}], ",", "val"}], 
         "}"}]}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"dataUpper", "=", 
      RowBox[{"Select", "[", 
       RowBox[{"dataCartesian", ",", 
        RowBox[{
         RowBox[{
          RowBox[{"#", "[", 
           RowBox[{"[", "2", "]"}], "]"}], ">=", "0"}], "&"}]}], "]"}]}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"dataLower", "=", 
      RowBox[{"dataUpper", "/.", " ", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"x_", ",", "y_", ",", "v_"}], "}"}], ":>", 
        RowBox[{"{", 
         RowBox[{"x", ",", 
          RowBox[{"-", "y"}], ",", "v"}], "}"}]}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"dataFull", "=", 
      RowBox[{"Join", "[", 
       RowBox[{"dataUpper", ",", "dataLower"}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
      "Create", " ", "2", "D", " ", "density", " ", "plot", " ", "with", " ", 
       "central", " ", "disk"}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"plot2D", "=", 
      RowBox[{"Show", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"ListDensityPlot", "[", "\[IndentingNewLine]", 
         RowBox[{"dataFull", ",", "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
            RowBox[{"InterpolationOrder", "->", "2"}], ","}], "*)"}], 
          "\[IndentingNewLine]", 
          RowBox[{"PlotLegends", "->", 
           RowBox[{"BarLegend", "[", 
            RowBox[{"Automatic", ",", 
             RowBox[{"LegendLabel", "->", 
              RowBox[{"Placed", "[", 
               RowBox[{
                RowBox[{"MaTeX", "[", "\"\<\\\\mathcal{N}^{(2)}\>\"", "]"}], 
                ",", "Above"}], "]"}]}]}], "]"}]}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"ColorFunction", "->", 
           RowBox[{"Function", "[", 
            RowBox[{"z", ",", 
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{"z", "<=", "threshold"}], ",", "Gray", ",", 
               RowBox[{
                RowBox[{"ColorData", "[", "\"\<Rainbow\>\"", "]"}], "[", 
                RowBox[{"Rescale", "[", 
                 RowBox[{"z", ",", 
                  RowBox[{"{", 
                   RowBox[{
                    RowBox[{"Min", "[", 
                    RowBox[{"dataTable", "[", 
                    RowBox[{"[", 
                    RowBox[{"All", ",", "3"}], "]"}], "]"}], "]"}], ",", 
                    RowBox[{"Max", "[", 
                    RowBox[{"dataTable", "[", 
                    RowBox[{"[", 
                    RowBox[{"All", ",", "3"}], "]"}], "]"}], "]"}]}], "}"}]}],
                  "]"}], "]"}]}], "]"}]}], "]"}]}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"ColorFunctionScaling", "->", "False"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"FrameLabel", "->", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"MaTeX", "[", "\"\<q_1 / L\>\"", "]"}], ",", 
             RowBox[{"MaTeX", "[", "\"\<q_2 / L\>\"", "]"}]}], "}"}]}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"PlotRange", "->", "plotRange"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"AspectRatio", "->", "1"}], ",", "\[IndentingNewLine]", 
          RowBox[{"ImageSize", "->", "400"}], ",", "\[IndentingNewLine]", 
          RowBox[{"RegionFunction", "->", 
           RowBox[{"Function", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"x", ",", "y", ",", "z"}], "}"}], ",", 
             RowBox[{
              RowBox[{"Sqrt", "[", 
               RowBox[{
                RowBox[{"x", "^", "2"}], "+", 
                RowBox[{"y", "^", "2"}]}], "]"}], ">=", 
