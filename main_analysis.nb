          RowBox[{"Thick", ",", "Dashed", ",", "Black", ",", 
           RowBox[{"Line", "[", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"1.0", ",", "yMin"}], "}"}], ",", 
