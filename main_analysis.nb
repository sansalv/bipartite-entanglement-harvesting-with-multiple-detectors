 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Define", " ", "Gaussian", " ", "smearing", " ", "and", " ", "switching", 
    " ", "functions", " ", "in", " ", "momentum", " ", "space"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"sFuncMomGaussian", "[", 
     RowBox[{"k_", ",", " ", "\[Sigma]_"}], "]"}], " ", ":=", " ", 
    RowBox[{"Exp", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "1"}], "/", "2"}], " ", 
      SuperscriptBox["k", "2"], " ", 
      SuperscriptBox["\[Sigma]", "2"]}], "]"}]}], " ", 
   RowBox[{"(*", 
    RowBox[{
    "With", " ", "corresponding", " ", "spatial", " ", "version", " ", "in", 
     " ", "n", " ", 
     RowBox[{"dimensions", ":", " ", 
      RowBox[{
       FormBox[
        FractionBox["1", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"2", " ", "Pi", " ", 
            SuperscriptBox["\[Sigma]", "2"]}], ")"}], 
          RowBox[{"n", "/", "2"}]]],
        TraditionalForm], 
       FormBox[
        RowBox[{"exp", "(", 
         RowBox[{"-", 
          FractionBox[
           SuperscriptBox["r", "2"], 
           RowBox[{"2", " ", 
            SuperscriptBox["\[Sigma]", "2"]}]]}], ")"}],
        TraditionalForm]}]}]}], "*)"}], ";"}]}]], "Input",
