        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"\[CapitalDelta]x", "==", "0"}], ",", 
          RowBox[{"Pii", "[", "\[CapitalOmega]", "]"}], ",", 
          RowBox[{
           RowBox[{
            FractionBox[
             RowBox[{"Exp", "[", 
              RowBox[{"\[Minus]", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"\[CapitalDelta]x", "/", 
                  RowBox[{"(", 
                   RowBox[{"2", " ", "\[Sigma]"}], ")"}]}], ")"}], "^", 
                "2"}]}], "]"}], 
             RowBox[{"8", " ", 
              RowBox[{"\[Pi]", "^", 
               RowBox[{"(", 
                RowBox[{"3", "/", "2"}], ")"}]}], " ", "\[CapitalDelta]x", 
              " ", "\[Sigma]"}]], "*", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"Re", "[", 
               RowBox[{
                RowBox[{"Exp", "[", 
                 RowBox[{
                  RowBox[{"\[Minus]", "\[ImaginaryI]"}], " ", 
                  "\[CapitalDelta]x", " ", "\[CapitalOmega]"}], "]"}], 
                RowBox[{"Erfi", "[", 
                 RowBox[{
                  RowBox[{"\[CapitalDelta]x", "/", 
                   RowBox[{"(", 
                    RowBox[{"2", " ", "\[Sigma]"}], ")"}]}], "+", 
                  RowBox[{
                  "\[ImaginaryI]", " ", "\[Sigma]", " ", 
                   "\[CapitalOmega]"}]}], "]"}]}], "]"}], "-", 
              RowBox[{"Sin", "[", 
               RowBox[{"\[CapitalDelta]x", " ", "\[CapitalOmega]"}], "]"}]}], 
             ")"}]}], "/.", " ", 
           RowBox[{"\[Sigma]", "->", 
            RowBox[{"Rt1", "/", "\[Alpha]1"}]}]}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"CijPlus", "[", 
         RowBox[{"\[CapitalDelta]x_", ",", "\[CapitalOmega]_"}], "]"}], ":=", 
        
        RowBox[{
         RowBox[{"Re", "[", "\[InvisibleSpace]", 
          FractionBox[
           RowBox[{
            RowBox[{"Exp", "[", 
             RowBox[{
              RowBox[{"\[Minus]", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"\[CapitalDelta]x", "/", 
                  RowBox[{"(", 
                   RowBox[{"2", " ", "\[Sigma]"}], ")"}]}], ")"}], "^", 
                "2"}]}], "-", 
              RowBox[{
              "\[ImaginaryI]", " ", "\[CapitalDelta]x", " ", 
               "\[CapitalOmega]"}]}], "]"}], 
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"Exp", "[", 
                RowBox[{
                "2", "\[ImaginaryI]", " ", "\[CapitalDelta]x", " ", 
                 "\[CapitalOmega]"}], "]"}], " ", 
               RowBox[{"Erfi", "[", 
                RowBox[{
                 RowBox[{"\[CapitalDelta]x", "/", 
                  RowBox[{"(", 
                   RowBox[{"2", " ", "\[Sigma]"}], ")"}]}], "-", 
                 RowBox[{
                 "\[ImaginaryI]", " ", "\[Sigma]", " ", "\[CapitalOmega]"}]}],
                 "]"}]}], "+", 
              RowBox[{"Erfi", "[", 
               RowBox[{
                RowBox[{"\[CapitalDelta]x", "/", 
                 RowBox[{"(", 
                  RowBox[{"2", " ", "\[Sigma]"}], ")"}]}], "+", 
                RowBox[{
                "\[ImaginaryI]", " ", "\[Sigma]", " ", "\[CapitalOmega]"}]}], 
               "]"}]}], ")"}]}], 
           RowBox[{"16", " ", 
            RowBox[{"Pi", "^", 
             RowBox[{"(", 
              RowBox[{"3", "/", "2"}], ")"}]}], "\[CapitalDelta]x", " ", 
            "\[Sigma]"}]], "]"}], "/.", " ", 
         RowBox[{"\[Sigma]", "->", 
          RowBox[{"Rt1", "/", "\[Alpha]1"}]}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"CijMinus", "[", 
         RowBox[{"\[CapitalDelta]x_", ",", "\[CapitalOmega]_"}], "]"}], ":=", 
        "\[InvisibleSpace]", 
        RowBox[{
         RowBox[{"-", 
          FractionBox[
           RowBox[{
            RowBox[{"Exp", "[", 
             RowBox[{"\[Minus]", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"\[CapitalDelta]x", "/", 
                 RowBox[{"(", 
                  RowBox[{"2", " ", "\[Sigma]"}], ")"}]}], ")"}], "^", 
               "2"}]}], "]"}], " ", 
            RowBox[{"Sin", "[", 
             RowBox[{"\[CapitalDelta]x", " ", "\[CapitalOmega]"}], "]"}]}], 
           RowBox[{"8", " ", 
            RowBox[{"Pi", "^", 
             RowBox[{"(", 
              RowBox[{"3", "/", "2"}], ")"}]}], " ", "\[CapitalDelta]x", " ", 
            "\[Sigma]"}]]}], "/.", " ", 
         RowBox[{"\[Sigma]", "->", 
          RowBox[{"Rt1", "/", "\[Alpha]1"}]}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"XijPlus", "[", 
         RowBox[{"\[CapitalDelta]x_", ",", "\[CapitalOmega]_"}], "]"}], ":=", 
        
        RowBox[{
         RowBox[{"-", 
          FractionBox[
           RowBox[{
            RowBox[{"Exp", "[", 
             RowBox[{"\[Minus]", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"\[Sigma]", " ", "\[CapitalOmega]"}], ")"}], "^", 
               "2"}]}], "]"}], " ", 
            RowBox[{"DawsonF", "[", 
             FractionBox["\[CapitalDelta]x", 
              RowBox[{"2", " ", "\[Sigma]"}]], "]"}]}], 
           RowBox[{"4", " ", 
            RowBox[{"Pi", "^", "2"}], " ", "\[CapitalDelta]x", " ", 
            "\[Sigma]"}]]}], "/.", " ", 
         RowBox[{"\[Sigma]", "->", 
          RowBox[{"Rt1", "/", "\[Alpha]1"}]}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"XijMinus", "[", 
         RowBox[{"\[CapitalDelta]x_", ",", "\[CapitalOmega]_"}], "]"}], ":=", 
        
        RowBox[{
         FractionBox[
          RowBox[{"\[ImaginaryI]", " ", 
           RowBox[{"Exp", "[", 
            RowBox[{
             RowBox[{"\[Minus]", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"\[CapitalDelta]x", "/", 
                 RowBox[{"(", 
                  RowBox[{"2", " ", "\[Sigma]"}], ")"}]}], ")"}], "^", 
               "2"}]}], "-", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"\[Sigma]", " ", "\[CapitalOmega]"}], ")"}], "^", 
              "2"}]}], "]"}]}], 
          RowBox[{"8", " ", 
           RowBox[{"Pi", "^", 
            RowBox[{"(", 
             RowBox[{"3", "/", "2"}], ")"}]}], " ", "\[CapitalDelta]x", " ", 
           "\[Sigma]"}]], "/.", " ", 
         RowBox[{"\[Sigma]", "->", 
          RowBox[{"Rt1", "/", "\[Alpha]1"}]}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Xij", "[", 
         RowBox[{"\[CapitalDelta]x_", ",", "\[CapitalOmega]_"}], "]"}], ":=", 
        
        RowBox[{
         RowBox[{"XijPlus", "[", 
          RowBox[{"\[CapitalDelta]x", ",", "\[CapitalOmega]"}], "]"}], "+", 
         RowBox[{"XijMinus", "[", 
          RowBox[{"\[CapitalDelta]x", ",", "\[CapitalOmega]"}], "]"}]}]}], 
       ";"}], "\[IndentingNewLine]", ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
       "Print", "[", 
        "\"\<Using numerical integrals for Cij and Xij terms...\>\"", "]"}], 
       ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Pii", "[", "\[CapitalOmega]_", "]"}], ":=", 
        RowBox[{"NIntegrate", "[", 
         RowBox[{
          RowBox[{"PiiIntegrand", "[", 
           RowBox[{"k", ",", "\[CapitalOmega]"}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", "kmin1", ",", "kmax1"}], "}"}], ",", " ", 
          RowBox[{"Method", "->", "\"\<Oscillatory\>\""}], ",", " ", 
          RowBox[{"AccuracyGoal", "->", "25"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Cij", "[", 
         RowBox[{"\[CapitalDelta]x_", ",", "\[CapitalOmega]_"}], "]"}], ":=", 
        
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"\[CapitalDelta]x", "==", "0"}], ",", 
          RowBox[{"Pii", "[", "\[CapitalOmega]", "]"}], ",", 
          RowBox[{"NIntegrate", "[", 
           RowBox[{
            RowBox[{"CijIntegrand", "[", 
             RowBox[{"k", ",", "\[CapitalDelta]x", ",", "\[CapitalOmega]"}], 
             "]"}], ",", 
            RowBox[{"{", 
             RowBox[{"k", ",", "kmin1", ",", "kmax1"}], "}"}], ",", " ", 
            RowBox[{"Method", "->", "\"\<Oscillatory\>\""}], ",", " ", 
            RowBox[{"AccuracyGoal", "->", "25"}]}], "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"XijPlus", "[", 
         RowBox[{"\[CapitalDelta]x_", ",", "\[CapitalOmega]_"}], "]"}], ":=", 
        
