Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"switchingMomGaussianTruncated", "[", 
    RowBox[{"\[Omega]_", ",", "\[Sigma]_", ",", "T_"}], "]"}], " ", ":=", 
   RowBox[{"Re", "[", " ", 
    RowBox[{
     FractionBox["1", "2"], " ", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", 
        FractionBox["1", "2"]}], " ", 
       SuperscriptBox["\[Sigma]", "2"], " ", 
       SuperscriptBox["\[Omega]", "2"]}]], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Erf", "[", 
        FractionBox[
         RowBox[{"T", "-", 
          RowBox[{"\[ImaginaryI]", " ", 
           SuperscriptBox["\[Sigma]", "2"], " ", "\[Omega]"}]}], 
         RowBox[{
          SqrtBox["2"], " ", "\[Sigma]"}]], "]"}], "+", 
       RowBox[{"Erf", "[", 
        FractionBox[
         RowBox[{"T", "+", 
          RowBox[{"\[ImaginaryI]", " ", 
           SuperscriptBox["\[Sigma]", "2"], " ", "\[Omega]"}]}], 
         RowBox[{
          SqrtBox["2"], " ", "\[Sigma]"}]], "]"}]}], ")"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"switchingMomCos2", "[", 
    RowBox[{"\[Omega]_", ",", "T_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "/", "T"}], ")"}], 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"Sin", "[", 
        RowBox[{"\[Omega]", " ", "T"}], "]"}], "/", "\[Omega]"}], "+", 
      RowBox[{
       RowBox[{"1", "/", "2"}], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"Sin", "[", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"\[Omega]", "-", 
              RowBox[{"\[Pi]", "/", "T"}]}], ")"}], " ", "T"}], "]"}], "/", 
          RowBox[{"(", 
           RowBox[{"\[Omega]", "-", 
            RowBox[{"\[Pi]", "/", "T"}]}], ")"}]}], "+", 
         RowBox[{
          RowBox[{"Sin", "[", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"\[Omega]", "+", 
              RowBox[{"\[Pi]", "/", "T"}]}], ")"}], " ", "T"}], "]"}], "/", 
          RowBox[{"(", 
           RowBox[{"\[Omega]", "+", 
            RowBox[{"\[Pi]", "/", "T"}]}], ")"}]}]}], ")"}]}]}], ")"}]}]}], 
  RowBox[{"(*", 
