Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Derivation", " ", "of", " ", "the", " ", "exact", " ", "compactly", " ", 
    "supported", " ", "smearing", " ", "and", " ", "switching", " ", 
    "functions"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"h", "[", 
      RowBox[{"q_", ",", "R_", ",", "\[Delta]_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "-", 
        RowBox[{
         RowBox[{"q", "^", "2"}], "/", 
         RowBox[{"R", "^", "2"}]}]}], ")"}], "^", "\[Delta]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"hNormalizationConstant3D", "[", 
      RowBox[{"R_", ",", "\[Delta]_"}], "]"}], ":=", 
     RowBox[{"1", "/", 
      RowBox[{"Integrate", "[", 
       RowBox[{
        RowBox[{"4", " ", "\[Pi]", " ", 
         RowBox[{"r", "^", "2"}], " ", 
         RowBox[{"h", "[", 
          RowBox[{"r", ",", "R", ",", "\[Delta]"}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"r", ",", "0", ",", "R"}], "}"}]}], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"hNormalizationConstant1D", "[", 
      RowBox[{"T_", ",", "\[Delta]_"}], "]"}], ":=", 
     RowBox[{"1", "/", 
      RowBox[{"Integrate", "[", 
       RowBox[{
        RowBox[{"h", "[", 
         RowBox[{"t", ",", "T", ",", "\[Delta]"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"t", ",", 
          RowBox[{"-", "T"}], ",", "T"}], "}"}]}], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"smearingFuncSpatCS", "[", 
      RowBox[{"r_", ",", "R_", ",", "\[Delta]_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"hNormalizationConstant3D", "[", 
       RowBox[{"R", ",", "\[Delta]"}], "]"}], " ", 
      RowBox[{"h", "[", 
       RowBox[{"r", ",", "R", ",", "\[Delta]"}], "]"}]}]}], " ", 
    RowBox[{"(*", 
     RowBox[{
     "smearing", " ", "function", " ", "in", " ", "spatial", " ", "space", 
      " ", 
      RowBox[{"wo", "/", " ", "compactification"}]}], "*)"}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"switchingFuncSpatCS", "[", 
      RowBox[{"t_", ",", "T_", ",", "\[Delta]_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"hNormalizationConstant1D", "[", 
       RowBox[{"T", ",", "\[Delta]"}], "]"}], " ", 
      RowBox[{"h", "[", 
       RowBox[{"t", ",", "T", ",", "\[Delta]"}], "]"}]}]}], 
    RowBox[{"(*", 
     RowBox[{
     "switching", " ", "function", " ", "in", " ", "spatial", " ", "space", 
      " ", 
      RowBox[{"wo", "/", " ", "compactification"}]}], "*)"}], ";"}], " ", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"smearingFuncMomCS", "[", 
      RowBox[{"k_", ",", "R_", ",", "\[Delta]_"}], "]"}], ":=", 
     RowBox[{"Assuming", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"R", ">", "0"}], ",", 
         RowBox[{"\[Delta]", ">", "1"}]}], "}"}], ",", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"4", " ", 
          RowBox[{"\[Pi]", "/", "k"}]}], ")"}], " ", 
        RowBox[{"Integrate", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"smearingFuncSpatCS", "[", 
            RowBox[{"r", ",", "R", ",", "\[Delta]"}], "]"}], " ", 
           RowBox[{"Sin", "[", 
            RowBox[{"k", " ", "r"}], "]"}], " ", "r"}], ",", 
          RowBox[{"{", 
           RowBox[{"r", ",", "0", ",", "R"}], "}"}]}], "]"}]}]}], "]"}]}], 
    RowBox[{"(*", 
     RowBox[{
     "compactified", " ", "smearing", " ", "function", " ", "in", " ", 
      "momentum", " ", "space"}], "*)"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"switchingFuncMomCS", "[", 
      RowBox[{"\[Omega]_", ",", "T_", ",", "\[Delta]_"}], "]"}], ":=", 
     RowBox[{"Assuming", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"T", ">", "0"}], ",", 
         RowBox[{"\[Delta]", ">", "1"}]}], "}"}], ",", 
       RowBox[{"Integrate", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"switchingFuncSpatCS", "[", 
           RowBox[{"t", ",", "T", ",", "\[Delta]"}], "]"}], " ", 
          RowBox[{"Exp", "[", 
           RowBox[{
            RowBox[{"-", "\[ImaginaryI]"}], " ", "\[Omega]", " ", "t"}], 
           "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"t", ",", 
           RowBox[{"-", "T"}], ",", "T"}], "}"}]}], "]"}]}], "]"}]}], 
    RowBox[{"(*", 
     RowBox[{
     "compactified", " ", "switching", " ", "function", " ", "in", " ", 
      "momentum", " ", "space"}], "*)"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Print", " ", "the", " ", "results"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"smearingFuncMomCS", "[", 
      RowBox[{"k", ",", "R", ",", "\[Delta]"}], "]"}], "]"}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"switchingFuncMomCS", "[", 
      RowBox[{"\[Omega]", ",", "T", ",", "\[Delta]"}], "]"}], "]"}], 
    ";"}]}]}]], "Input",
