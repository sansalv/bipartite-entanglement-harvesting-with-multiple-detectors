Cell[CellGroupData[{

Cell["Set the optimal 2 - detector energy gap \[CapitalOmega]2", "Subsection",
 CellChangeTimes->{{3.979189406982782*^9, 
  3.979189417711851*^9}},ExpressionUUID->"51c99d13-2e6e-4308-ac1b-\
d23f14dc3337"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[CapitalOmega]2", "=", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"isGaussianSwitching", " ", "&&", " ", "isPointlikeDetectors"}], 
     ",", 
     RowBox[{"SetPrecision", "[", 
      RowBox[{
       RowBox[{"24.4931496826", "/", "Rt1"}], ",", "prec"}], "]"}], ",", 
     RowBox[{"SetPrecision", "[", 
      RowBox[{"\[CapitalOmega]Opt", ",", "prec"}], "]"}]}], "]"}]}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"Gaussian", "&"}], "PL", " ", "value", " ", "computed", " ", 
     "with", " ", 
     RowBox[{"10", "^", "6"}], " ", "datapoints", " ", 
     RowBox[{"in", " ", "[", 
      RowBox[{
       RowBox[{"24.4931", "/", "Rt1"}], ",", 
       RowBox[{"24.4932", "/", "Rt1"}]}], "]"}]}], "]"}], "*)"}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.979189406982782*^9, 3.9791894090786858`*^9}},
 CellLabel->"In[65]:=",ExpressionUUID->"446449be-a9fa-491b-a5db-b69325ad6307"]
}, Open  ]]
}, Open  ]],

