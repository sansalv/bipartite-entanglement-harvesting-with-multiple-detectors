Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"neg3ABA", "[", " ", 
    RowBox[{"\[CapitalOmega]_", ",", 
     RowBox[{"l_", ":", "L1"}]}], "]"}], " ", ":=", " ", 
   RowBox[{"Max", "[", 
    RowBox[{"0", ",", " ", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{"Pii", "[", "\[CapitalOmega]", "]"}]}], " ", "-", " ", 
      RowBox[{
       RowBox[{"1", "/", "2"}], " ", 
       RowBox[{"Cij", "[", 
        RowBox[{
         RowBox[{"2", "l"}], ",", " ", "\[CapitalOmega]"}], "]"}]}], " ", "+",
       " ", 
      RowBox[{
       RowBox[{"1", "/", "2"}], " ", 
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{"8", " ", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"-", 
             RowBox[{"XijPlus", "[", 
              RowBox[{"l", ",", " ", "\[CapitalOmega]"}], "]"}]}], ")"}], "^",
            "2"}]}], " ", "+", " ", 
         RowBox[{
          RowBox[{"Cij", "[", 
           RowBox[{
            RowBox[{"2", "l"}], ",", " ", "\[CapitalOmega]"}], "]"}], "^", 
          "2"}]}], "]"}]}]}]}], "]"}]}], 
  RowBox[{"(*", 
