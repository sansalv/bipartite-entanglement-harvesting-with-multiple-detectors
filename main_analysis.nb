Cell[CellGroupData[{

Cell["Define 3 detector LO negativity analytically ", "Subsection",
 GeneratedCell->False,
 CellAutoOverwrite->False,
 CellChangeTimes->{{3.958205158906555*^9, 3.9582051695296087`*^9}, {
   3.958205286028606*^9, 3.9582052953444843`*^9}, {3.9582056233054523`*^9, 
   3.958205634925825*^9}, {3.958205735837715*^9, 3.958205818146904*^9}, {
   3.958205878319593*^9, 3.958205901922617*^9}, {3.9582059366112556`*^9, 
   3.958205982578558*^9}, {3.958206017605708*^9, 3.9582060498093357`*^9}, {
   3.95820609316216*^9, 3.9582061129334383`*^9}, 3.958206167695161*^9, 
   3.9584425304931393`*^9, 3.958446379053203*^9, 3.958448306348455*^9, 
   3.958449106925889*^9, 3.958449178521205*^9, {3.958464731197926*^9, 
   3.958464740555788*^9}, {3.958464786148118*^9, 3.958464789308217*^9}, {
   3.960523170442635*^9, 3.960523188811133*^9}, {3.964505990981155*^9, 
   3.9645060117579823`*^9}, {3.9785126559751253`*^9, 
   3.9785126857915163`*^9}, {3.978590718523898*^9, 
   3.978590718835306*^9}},ExpressionUUID->"fcfb4e78-1a77-45bc-883b-\
96b1c3dacd7e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Define", " ", "LO", " ", "negativity", " ", "function", " ", "where", " ",
     "one", " ", "detector", " ", "position", " ", "is", " ", "given", " ", 
    "in", " ", "polar", " ", "coordinates"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"neg3Detectors", "[", 
      RowBox[{"\[CapitalOmega]_", ",", "r_", ",", "\[Theta]_", ",", 
       RowBox[{"l_", ":", "L1"}]}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "P", ",", "Xl", ",", "Xr", ",", "x", ",", "Cx", ",", "S", ",", "R", 
         ",", "\[Rho]", ",", "\[Phi]", ",", "eigenvals", ",", "negativity"}], 
        "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"P", "=", 
         RowBox[{"Pii", "[", "\[CapitalOmega]", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Xl", "=", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"isGaussianSwitching", "&&", "isPointlikeDetectors"}], ",", 
           RowBox[{"Xij", "[", 
            RowBox[{"l", ",", "\[CapitalOmega]"}], "]"}], ",", 
           RowBox[{"XijPlus", "[", 
            RowBox[{"l", ",", "\[CapitalOmega]"}], "]"}]}], "]"}]}], 
        RowBox[{"(*", 
         RowBox[{
         "Use", " ", "complex", " ", "value", " ", "of", " ", "Mij", " ", 
          "when", " ", "there", " ", "is", " ", "no", " ", "compact", " ", 
          "support"}], "*)"}], ";", "\[IndentingNewLine]", 
        RowBox[{"Xr", "=", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"isGaussianSwitching", "&&", "isPointlikeDetectors"}], ",", 
           RowBox[{"Xij", "[", 
            RowBox[{"r", ",", "\[CapitalOmega]"}], "]"}], ",", 
           RowBox[{"XijPlus", "[", 
            RowBox[{"r", ",", "\[CapitalOmega]"}], "]"}]}], "]"}]}], 
        RowBox[{"(*", 
         RowBox[{
         "Use", " ", "complex", " ", "value", " ", "of", " ", "Mij", " ", 
          "when", " ", "there", " ", "is", " ", "no", " ", "compact", " ", 
          "support"}], "*)"}], ";", "\[IndentingNewLine]", 
        RowBox[{"x", "=", 
         RowBox[{"Sqrt", "[", 
          RowBox[{
           RowBox[{"r", "^", "2"}], "+", 
           RowBox[{"l", "^", "2"}], "-", 
           RowBox[{"2", "r", " ", "l", " ", 
            RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Cx", "=", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"x", "/", "l"}], "<", "1*^-7"}], " ", ",", 
           RowBox[{"Pii", "[", "\[CapitalOmega]", "]"}], ",", 
           RowBox[{"Cij", "[", 
            RowBox[{"x", ",", "\[CapitalOmega]"}], "]"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"S", "=", 
         RowBox[{"Sqrt", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Abs", "[", "Cx", "]"}], "^", "2"}], "+", 
           RowBox[{
            RowBox[{"Abs", "[", "Xr", "]"}], "^", "2"}], "+", 
           RowBox[{
            RowBox[{"Abs", "[", "Xl", "]"}], "^", "2"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"R", "=", 
         RowBox[{"Re", "[", 
          RowBox[{"Cx", " ", "Xr", " ", 
           RowBox[{"Conjugate", "[", "Xl", "]"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"\[Rho]", "=", 
         RowBox[{
          RowBox[{"Sqrt", "[", 
           RowBox[{"4", "/", "3"}], "]"}], "S"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"\[Phi]", "=", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "/", "3"}], ")"}], " ", 
          RowBox[{"ArcCos", "[", 
           RowBox[{"3", " ", 
            RowBox[{"Sqrt", "[", "3", "]"}], " ", 
            RowBox[{"R", "/", 
             RowBox[{"S", "^", "3"}]}]}], "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"eigenvals", "=", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"P", "+", 
            RowBox[{"\[Rho]", " ", 
             RowBox[{"Cos", "[", 
              RowBox[{"\[Phi]", "+", 
               RowBox[{"2", " ", "Pi", " ", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"k", "-", "1"}], ")"}], "/", "3"}]}]}], "]"}]}]}], 
           ",", 
           RowBox[{"{", 
            RowBox[{"k", ",", "1", ",", "3"}], "}"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"negativity", "=", 
         RowBox[{"Total", "[", 
          RowBox[{"-", 
           RowBox[{"Select", "[", 
            RowBox[{"eigenvals", ",", 
             RowBox[{
              RowBox[{"#", "<", "0"}], "&"}]}], "]"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", "negativity"}]}], "\[IndentingNewLine]", 
      "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Define", " ", "a", " ", "table", " ", "version", " ", "of", " ", 
     "neg3Detectors"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"negTable3Detectors", "[", 
      RowBox[{"\[CapitalOmega]_", ",", 
       RowBox[{"sampleR_", ":", 
        RowBox[{"Range", "[", 
         RowBox[{"L1", ",", 
          RowBox[{"3.4", "L1"}], ",", 
          RowBox[{"0.01", "L1"}]}], "]"}]}], ",", 
       RowBox[{"sample\[Theta]_", ":", 
        RowBox[{"Range", "[", 
         RowBox[{"0", ",", "Pi", ",", 
          RowBox[{"Pi", "/", "128"}]}], "]"}]}], ",", 
       RowBox[{"l_", ":", "L1"}]}], "]"}], ":=", 
     RowBox[{"Join", "@@", 
      RowBox[{"ParallelTable", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"r", "/", "l"}], ",", 
          RowBox[{"\[Theta]", "/", "\[Pi]"}], ",", 
          RowBox[{"neg3Detectors", "[", 
           RowBox[{"\[CapitalOmega]", ",", "r", ",", "\[Theta]", ",", "l"}], 
           "]"}]}], "}"}], ",", "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"r", ",", "sampleR"}], "}"}], ",", "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"\[Theta]", ",", "sample\[Theta]"}], "}"}]}], 
       "\[IndentingNewLine]", "]"}]}]}], ";"}]}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.950855911010953*^9, 3.950855979197459*^9}, {
