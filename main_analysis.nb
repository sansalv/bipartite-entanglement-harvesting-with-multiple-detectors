      RowBox[{
       RowBox[{"{", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"1", "/", "T"}], ")"}], 
           RowBox[{
            RowBox[{"Cos", "[", 
             RowBox[{"Pi", " ", 
              RowBox[{"t", "/", 
               RowBox[{"(", 
                RowBox[{"2", " ", "T"}], ")"}]}]}], "]"}], "^", "2"}]}], ",", 
          
          RowBox[{
           RowBox[{"Abs", "[", "t", "]"}], "<=", "T"}]}], "}"}], "}"}], ",", 
       "0"}], "]"}]}], ";"}], "*)"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"switchingMomSech2", "[", 
