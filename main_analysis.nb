Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "Define", " ", "a", " ", "version", " ", "of", " ", "the", " ", 
     "Gaussian", " ", 
     RowBox[{"smearing", "/", "switching"}], " ", "which", " ", "has", " ", 
     "been", " ", "compactified", " ", "by", " ", "cutting", " ", "the", " ", 
     "tails"}], " ", "=", 
    RowBox[{">", " ", 
     RowBox[{"compactified", " ", 
      RowBox[{"between", " ", "[", 
       RowBox[{
        RowBox[{"-", "R"}], ",", "R"}], "]"}]}]}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"sFuncMomGaussianTruncated", "[", 
      RowBox[{"k_", ",", "\[Sigma]_", ",", "R_"}], "]"}], " ", ":=", " ", 
     RowBox[{
      FractionBox["1", "2"], " ", 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{
        RowBox[{"-", 
         FractionBox["1", "2"]}], " ", 
        SuperscriptBox["\[Sigma]", "2"], " ", 
        SuperscriptBox["k", "2"]}]], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Erf", "[", 
         FractionBox[
          RowBox[{"R", "-", 
           RowBox[{"\[ImaginaryI]", " ", 
            SuperscriptBox["\[Sigma]", "2"], " ", "k"}]}], 
          RowBox[{
           SqrtBox["2"], " ", "\[Sigma]"}]], "]"}], "+", 
        RowBox[{"Erf", "[", 
         FractionBox[
          RowBox[{"R", "+", 
           RowBox[{"\[ImaginaryI]", " ", 
            SuperscriptBox["\[Sigma]", "2"], " ", "k"}]}], 
          RowBox[{
           SqrtBox["2"], " ", "\[Sigma]"}]], "]"}]}], ")"}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Plateau", " ", "bumb", " ", "function"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"h", "[", "u_", "]"}], ":=", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"u", "<=", "0."}], ",", "0.", ",", 
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"-", "1."}], "/", "u"}], "]"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"smoothStep", "[", "x_", "]"}], ":=", 
     RowBox[{"Which", "[", 
