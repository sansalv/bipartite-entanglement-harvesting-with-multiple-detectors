       RowBox[{"x", "<=", "0."}], ",", "0.", ",", 
       RowBox[{"x", ">=", "1."}], ",", "1.", ",", "True", ",", 
       RowBox[{
        RowBox[{"h", "[", "x", "]"}], "/", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"h", "[", "x", "]"}], "+", 
          RowBox[{"h", "[", 
           RowBox[{"1.", "-", "x"}], "]"}]}], ")"}]}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"switchingSpatPlateauRaw", "[", 
