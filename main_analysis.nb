      "]"}], ":=", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{"(", 
        RowBox[{"1", "/", 
         RowBox[{"(", 
          RowBox[{"4", " ", 
           RowBox[{"\[Pi]", "^", "2"}], " ", "\[CapitalDelta]x"}], ")"}]}], 
        ")"}]}], 
      RowBox[{"Sin", "[", 
       RowBox[{"k", " ", "\[CapitalDelta]x"}], "]"}], " ", 
      RowBox[{
       RowBox[{"Abs", "[", 
        RowBox[{"smearingMom", "[", "k", "]"}], "]"}], "^", "2"}], "  ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"switchingMom", "[", 
         RowBox[{"k", "+", "\[CapitalOmega]"}], "]"}], " ", 
        RowBox[{"switchingMom", "[", 
         RowBox[{"k", "-", "\[CapitalOmega]"}], "]"}]}], ")"}]}]}], 
    RowBox[{"(*", 
     RowBox[{"also", " ", "denoted", " ", "X_ij"}], "*)"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Define", " ", "the", " ", "reduced", " ", "density", " ", "matrix", " ", 
     "components"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"isPointlikeDetectors", " ", "&&", " ", "isGaussianSwitching"}],
       ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
       "Print", "[", 
        "\"\<Using closed forms for Cij and Xij terms since we have Gaussian \
switching and point-like detectors...\>\"", "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Pii", "[", "\[CapitalOmega]_", "]"}], ":=", 
        RowBox[{
         FractionBox[
          RowBox[{
           RowBox[{"Exp", "[", 
            RowBox[{"-", 
             RowBox[{
              RowBox[{"(", 
