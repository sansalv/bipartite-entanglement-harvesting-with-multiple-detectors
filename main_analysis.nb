874f39519c9b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", "Compute", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"dataNeg4AsymmVaryThetasOmega2", "=", 
     RowBox[{"Join", " ", "@@", 
      RowBox[{"ParallelTable", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"\[Theta]21", "/", "Pi"}], ",", 
          RowBox[{"\[Theta]32", "/", "Pi"}], ",", 
          RowBox[{"neg4Asymm", "[", 
           RowBox[{"\[CapitalOmega]2", ",", "\[Theta]21", ",", "\[Theta]32"}],
            "]"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"\[Theta]21", ",", 
          RowBox[{"Subdivide", "[", 
           RowBox[{"0", ",", 
            RowBox[{"2", "Pi"}], ",", "100"}], "]"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"\[Theta]32", ",", 
          RowBox[{"Subdivide", "[", 
           RowBox[{"0.000000000000001", ",", 
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{"2", "-", "1*^-15"}], ")"}], "Pi"}], "-", 
             "\[Theta]21"}], ",", "100"}], "]"}]}], "}"}]}], "]"}]}]}], ";"}],
    "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"dataNeg4AsymmVaryThetasMax", "=", 
     RowBox[{"Join", " ", "@@", 
      RowBox[{"ParallelTable", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"\[Theta]21", ",", "\[Theta]32", ",", 
          RowBox[{"neg4Asymm", "[", 
           RowBox[{"2003.392", ",", "\[Theta]21", ",", "\[Theta]32"}], 
           "]"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"\[Theta]21", ",", 
          RowBox[{"Subdivide", "[", 
           RowBox[{"0", ",", 
            RowBox[{"2", "Pi"}], ",", "100"}], "]"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"\[Theta]32", ",", 
          RowBox[{"Subdivide", "[", 
           RowBox[{"0", ",", 
            RowBox[{
             RowBox[{"2", "Pi"}], "-", "\[Theta]21"}], ",", "100"}], "]"}]}], 
         "}"}]}], "]"}]}]}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.961741924058876*^9, 3.961741981273416*^9}, 
