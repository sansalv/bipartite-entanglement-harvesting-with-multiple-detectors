Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Switch", " ", "to", " ", "Gaussian", " ", "and", " ", "compute", " ", 
    "for", " ", "comparison"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"sample\[CapitalOmega]", "=", 
     RowBox[{"Subdivide", "[", 
      RowBox[{
       RowBox[{"0.1", "/", "Rt1"}], ",", 
       RowBox[{"37", "/", "Rt1"}], ",", "1000"}], "]"}]}], 
    RowBox[{"(*", 
     RowBox[{"Enter", " ", "sample\[CapitalOmega]"}], "*)"}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "dataGaussianPii", ",", "dataGaussianXij", ",", "dataGaussianXijPlus", 
       ",", "dataGaussianCijSqrt2", ",", "dataGaussianCij2"}], "}"}], "=", 
     RowBox[{"Block", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "isGaussianSwitching", ",", "isPointlikeDetectors", ",", "Pii", ",", 
         "Cij", ",", "Xij", ",", "XijPlus", ",", "XijMinus"}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{"isGaussianSwitching", ",", "isPointlikeDetectors"}], "}"}],
          "=", 
         RowBox[{"{", 
          RowBox[{"True", ",", "True"}], "}"}]}], ";", "\[IndentingNewLine]", 
        
        RowBox[{
         RowBox[{"Pii", "[", "\[CapitalOmega]_", "]"}], ":=", 
         RowBox[{
          FractionBox[
           RowBox[{
            RowBox[{"Exp", "[", 
             RowBox[{"-", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"\[Sigma]", " ", "\[CapitalOmega]"}], ")"}], "^", 
               "2"}]}], "]"}], "-", 
            RowBox[{
             RowBox[{"Sqrt", "[", "Pi", "]"}], " ", "\[Sigma]", " ", 
             "\[CapitalOmega]", " ", 
             RowBox[{"Erfc", "[", 
              RowBox[{"\[Sigma]", " ", "\[CapitalOmega]"}], "]"}]}]}], 
           RowBox[{"8", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"Pi", " ", "\[Sigma]"}], ")"}], "^", "2"}]}]], "/.", 
          " ", 
          RowBox[{"\[Sigma]", "->", 
           RowBox[{"Rt1", "/", "\[Alpha]1"}]}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Xij", "[", 
          RowBox[{"\[CapitalDelta]x_", ",", "\[CapitalOmega]_"}], "]"}], ":=", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", 
             FractionBox[
              RowBox[{
               RowBox[{"Exp", "[", 
                RowBox[{"\[Minus]", 
                 RowBox[{
                  RowBox[{"(", 
                   RowBox[{"\[Sigma]", " ", "\[CapitalOmega]"}], ")"}], "^", 
                  "2"}]}], "]"}], " ", 
               RowBox[{"DawsonF", "[", 
                FractionBox["\[CapitalDelta]x", 
                 RowBox[{"2", " ", "\[Sigma]"}]], "]"}]}], 
              RowBox[{"4", " ", 
               RowBox[{"Pi", "^", "2"}], " ", "\[CapitalDelta]x", " ", 
               "\[Sigma]"}]]}], "+", 
            FractionBox[
             RowBox[{"\[ImaginaryI]", " ", 
              RowBox[{"Exp", "[", 
               RowBox[{
                RowBox[{"\[Minus]", 
                 RowBox[{
                  RowBox[{"(", 
                   RowBox[{"\[CapitalDelta]x", "/", 
                    RowBox[{"(", 
                    RowBox[{"2", " ", "\[Sigma]"}], ")"}]}], ")"}], "^", 
                  "2"}]}], "-", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"\[Sigma]", " ", "\[CapitalOmega]"}], ")"}], "^", 
                 "2"}]}], "]"}]}], 
             RowBox[{"8", " ", 
              RowBox[{"Pi", "^", 
               RowBox[{"(", 
                RowBox[{"3", "/", "2"}], ")"}]}], " ", "\[CapitalDelta]x", 
              " ", "\[Sigma]"}]]}], ")"}], "/.", " ", 
          RowBox[{"\[Sigma]", "->", 
           RowBox[{"Rt1", "/", "\[Alpha]1"}]}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Cij", "[", 
          RowBox[{"\[CapitalDelta]x_", ",", "\[CapitalOmega]_"}], "]"}], ":=", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"\[CapitalDelta]x", "==", "0"}], ",", 
           RowBox[{"Pii", "[", "\[CapitalOmega]", "]"}], ",", 
           RowBox[{
            RowBox[{
             FractionBox[
              RowBox[{"Exp", "[", 
               RowBox[{"\[Minus]", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"\[CapitalDelta]x", "/", 
                   RowBox[{"(", 
                    RowBox[{"2", " ", "\[Sigma]"}], ")"}]}], ")"}], "^", 
                 "2"}]}], "]"}], 
              RowBox[{"8", " ", 
               RowBox[{"\[Pi]", "^", 
                RowBox[{"(", 
                 RowBox[{"3", "/", "2"}], ")"}]}], " ", "\[CapitalDelta]x", 
               " ", "\[Sigma]"}]], "*", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"Re", "[", 
                RowBox[{
                 RowBox[{"Exp", "[", 
                  RowBox[{
                   RowBox[{"\[Minus]", "\[ImaginaryI]"}], " ", 
                   "\[CapitalDelta]x", " ", "\[CapitalOmega]"}], "]"}], 
                 RowBox[{"Erfi", "[", 
                  RowBox[{
                   RowBox[{"\[CapitalDelta]x", "/", 
                    RowBox[{"(", 
                    RowBox[{"2", " ", "\[Sigma]"}], ")"}]}], "+", 
                   RowBox[{
                   "\[ImaginaryI]", " ", "\[Sigma]", " ", 
                    "\[CapitalOmega]"}]}], "]"}]}], "]"}], "-", 
               RowBox[{"Sin", "[", 
                RowBox[{"\[CapitalDelta]x", " ", "\[CapitalOmega]"}], "]"}]}],
               ")"}]}], "/.", " ", 
            RowBox[{"\[Sigma]", "->", 
             RowBox[{"Rt1", "/", "\[Alpha]1"}]}]}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"XijPlus", "[", 
          RowBox[{"\[CapitalDelta]x_", ",", "\[CapitalOmega]_"}], "]"}], ":=", 
         RowBox[{
          RowBox[{"-", 
           FractionBox[
            RowBox[{
             RowBox[{"Exp", "[", 
              RowBox[{"\[Minus]", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"\[Sigma]", " ", "\[CapitalOmega]"}], ")"}], "^", 
                "2"}]}], "]"}], " ", 
             RowBox[{"DawsonF", "[", 
              FractionBox["\[CapitalDelta]x", 
               RowBox[{"2", " ", "\[Sigma]"}]], "]"}]}], 
            RowBox[{"4", " ", 
             RowBox[{"Pi", "^", "2"}], " ", "\[CapitalDelta]x", " ", 
             "\[Sigma]"}]]}], "/.", " ", 
          RowBox[{"\[Sigma]", "->", 
           RowBox[{"Rt1", "/", "\[Alpha]1"}]}]}]}], ";", 
