Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"NOTE", ":", " ", 
     RowBox[{
     "make", " ", "sure", " ", "that", " ", "you", " ", "have", " ", "some", 
      " ", "CP", " ", "switching", " ", "function", " ", "in", " ", "the", 
      " ", "setup"}]}], ",", " ", 
    RowBox[{"and", " ", "not", " ", 
     RowBox[{"Gaussian", ".", " ", "Also"}]}], ",", " ", 
    RowBox[{
    "run", " ", "the", " ", "Gaussian", " ", "tables", " ", "before", " ", 
     RowBox[{"this", "."}]}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"sample\[CapitalOmega]", "=", 
     RowBox[{"Subdivide", "[", 
      RowBox[{
       RowBox[{"0.1", "/", "Rt1"}], ",", 
       RowBox[{"42.1", "/", "Rt1"}], ",", "500"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"minDelta", "=", "0.00001"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"maxDelta", "=", "30.00001"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"i", "=", "1"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"delta", "=", "minDelta"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"While", "[", 
    RowBox[{
     RowBox[{"delta", "<=", "maxDelta"}], ",", "\[IndentingNewLine]", 
     RowBox[{"Block", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "switchingMom", ",", "dataNeg2", ",", "dataNeg3ABA", ",", 
         "dataNeg4DiagonalSquare", ",", "dataNegTables", ",", "cpPlot"}], 
        "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"switchingMom", "[", "\[Omega]_", "]"}], ":=", 
         RowBox[{"switchingMomCompactifiedPolynomial", "[", 
          RowBox[{"\[Omega]", ",", "Rt1", ",", "delta"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"dataNeg2", "=", 
         RowBox[{"ParallelTable", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"\[CapitalOmega]", " ", "Rt1"}], ",", 
             RowBox[{"neg2Detectors", "[", 
              RowBox[{"L1", ",", "\[CapitalOmega]"}], "]"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"\[CapitalOmega]", ",", "sample\[CapitalOmega]"}], 
            "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"dataNeg3ABA", "=", 
         RowBox[{"ParallelTable", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"\[CapitalOmega]", " ", "Rt1"}], ",", 
             RowBox[{"neg3ABA", "[", "\[CapitalOmega]", "]"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"\[CapitalOmega]", ",", "sample\[CapitalOmega]"}], 
            "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"dataNeg4DiagonalSquare", "=", 
         RowBox[{"ParallelTable", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"\[CapitalOmega]", " ", "Rt1"}], ",", 
             RowBox[{"neg4ModTetrahedron", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"Sqrt", "[", "2", "]"}], "L1"}], ",", 
               "\[CapitalOmega]"}], "]"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"\[CapitalOmega]", ",", "sample\[CapitalOmega]"}], 
            "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"dataNegTables", "=", 
         RowBox[{"{", 
          RowBox[{
          "dataGaussianNeg2", ",", "dataNeg2", ",", "dataGaussianNeg3ABA", 
           ",", "dataNeg3ABA", ",", "dataGaussianNeg4DiagonalSquare", ",", 
           "dataNeg4DiagonalSquare"}], "}"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"cpPlot", "=", 
         RowBox[{"plotVsGaussianFunc", "[", 
          RowBox[{"delta", ",", "dataNegTables", ",", "0.7"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Export", "[", 
         RowBox[{
          RowBox[{"FileNameJoin", "[", 
           RowBox[{"{", 
            RowBox[{"imageFolderPath", ",", 
             RowBox[{"\"\</animations/cp_switching/frames/frame-\>\"", " ", "<>", 
              RowBox[{"IntegerString", "[", 
               RowBox[{"i", ",", "10", ",", "3"}], "]"}], "<>", " ", 
              "\"\<.png\>\""}]}], "}"}], "]"}], ",", "cpPlot", ",", 
          RowBox[{"ImageResolution", "->", "200"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"i", "+=", "1"}], ";", "\[IndentingNewLine]", 
        RowBox[{"delta", "+=", "0.2"}], ";"}]}], "\[IndentingNewLine]", 
      "]"}]}], "\[IndentingNewLine]", "]"}]}]}]], "Input",
