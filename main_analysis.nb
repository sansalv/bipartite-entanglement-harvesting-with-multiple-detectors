Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Define", " ", "the", " ", "general", " ", 
    FormBox[
     TemplateBox[<|"boxes" -> FormBox[
         SubscriptBox[
          OverscriptBox["\[Rho]", "~"], "1"], TraditionalForm], 
       "errors" -> {}, "input" -> "\\tilde\\rho_1", "state" -> "Boxes"|>,
      "TeXAssistantTemplate"],
     TraditionalForm], " ", "block", " ", "as", " ", "a", " ", "function", 
    " ", "of", " ", "the", " ", "detector", " ", "count"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"tildeRho1Chain", "[", 
      RowBox[{"N_", ",", "\[CapitalOmega]_", ",", 
       RowBox[{"l_", ":", "L1"}]}], "]"}], ":=", 
     RowBox[{"Module", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "nB", ",", "nA", ",", "maxL", ",", "Cvals", ",", "Xvals", ",", 
         "kindex", ",", "elem"}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"nA", "=", 
         RowBox[{"Ceiling", "[", 
          RowBox[{"N", "/", "2"}], "]"}]}], 
        RowBox[{"(*", 
         RowBox[{"#", " ", "A", " ", "detectors"}], "*)"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"nB", "=", 
         RowBox[{"Floor", "[", 
          RowBox[{"N", "/", "2"}], "]"}]}], 
        RowBox[{"(*", 
         RowBox[{"#", " ", "B", " ", "detectors"}], "*)"}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"Cvals", "=", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"nA", "==", "1"}], ",", 
           RowBox[{"{", 
            RowBox[{"Pii", "[", "\[CapitalOmega]", "]"}], "}"}], ",", 
           RowBox[{"Prepend", "[", 
            RowBox[{
             RowBox[{"Table", "[", 
              RowBox[{
               RowBox[{"Cij", "[", 
                RowBox[{
                 RowBox[{"2", 
                  RowBox[{"(", 
                   RowBox[{"k", "-", "1"}], ")"}], "l"}], ",", 
                 "\[CapitalOmega]"}], "]"}], ",", 
               RowBox[{"{", 
                RowBox[{"k", ",", "2", ",", "nA"}], "}"}]}], "]"}], ",", 
             RowBox[{"Pii", "[", "\[CapitalOmega]", "]"}]}], "]"}]}], "]"}]}],
         ";", "\[IndentingNewLine]", 
        RowBox[{"Xvals", "=", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"Xij", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"2", "k"}], "-", "1"}], ")"}], "l"}], ",", 
             "\[CapitalOmega]"}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"k", ",", "1", ",", "nB"}], "}"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"kindex", "[", 
          RowBox[{"r_", ",", "s_"}], "]"}], ":=", 
         RowBox[{"Max", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"r", "-", "nA"}], ")"}], "-", "s", "+", "1"}], ",", 
           RowBox[{"s", "-", 
            RowBox[{"(", 
             RowBox[{"r", "-", "nA"}], ")"}]}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"elem", "[", 
          RowBox[{"i_", ",", "j_"}], "]"}], ":=", 
         RowBox[{"Which", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{
            RowBox[{"i", "<=", "nB"}], "&&", 
            RowBox[{"j", "<=", "nB"}]}], ",", 
           RowBox[{"Cvals", "[", 
            RowBox[{"[", 
             RowBox[{
              RowBox[{"Abs", "[", 
               RowBox[{"i", "-", "j"}], "]"}], "+", "1"}], "]"}], "]"}], 
           RowBox[{"(*", 
            RowBox[{
             RowBox[{"top", " ", "left", " ", "block", " ", "element"}], ",", 
             " ", "C_BB"}], "*)"}], ",", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"i", ">", "nB"}], "&&", 
            RowBox[{"j", ">", "nB"}]}], ",", 
           RowBox[{"Cvals", "[", 
            RowBox[{"[", 
             RowBox[{
              RowBox[{"Abs", "[", 
               RowBox[{"i", "-", "j"}], "]"}], "+", "1"}], "]"}], "]"}], 
           RowBox[{"(*", 
            RowBox[{
             RowBox[{"bottom", " ", "right", " ", "block", " ", "element"}], 
             ",", " ", "C_AA"}], "*)"}], ",", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"i", ">", "nB"}], "&&", 
            RowBox[{"j", "<=", "nB"}]}], ",", 
           RowBox[{"Xvals", "[", 
            RowBox[{"[", 
             RowBox[{"kindex", "[", 
              RowBox[{"i", ",", "j"}], "]"}], "]"}], "]"}], 
           RowBox[{"(*", 
            RowBox[{
             RowBox[{"bottom", " ", "left", " ", "block", " ", "element"}], 
             ",", " ", "X_BA"}], "*)"}], ",", "\[IndentingNewLine]", "True", 
           ",", 
           RowBox[{"Conjugate", "[", 
            RowBox[{"elem", "[", 
             RowBox[{"j", ",", "i"}], "]"}], "]"}]}], 
          RowBox[{"(*", 
           RowBox[{
            RowBox[{"top", " ", "right", " ", "block", " ", "element"}], ",", 
            " ", 
            RowBox[{
             RowBox[{
              RowBox[{"(", "X_BA", ")"}], "^"}], "\\", "dag"}]}], "*)"}], 
          "\[IndentingNewLine]", "]"}]}], ";", "\[IndentingNewLine]", 
        "\[IndentingNewLine]", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"elem", "[", 
           RowBox[{"i", ",", "j"}], "]"}], ",", 
          RowBox[{"{", 
