Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"neg2GaussianAnalytExpWithOnlyXPlus", "[", 
    RowBox[{"\[CapitalDelta]x_", ",", "\[CapitalOmega]_", ",", "\[Sigma]_"}], 
    "]"}], ":=", 
   RowBox[{"Max", "[", 
    RowBox[{"0", ",", 
     RowBox[{
      FractionBox[
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"-", 
          SuperscriptBox["\[Sigma]", "2"]}], " ", 
         SuperscriptBox["\[CapitalOmega]", "2"]}], "]"}], 
       RowBox[{"8", " ", 
        SuperscriptBox["\[Pi]", "2"], " ", "\[CapitalDelta]x", " ", 
        SuperscriptBox["\[Sigma]", "2"]}]], 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"2", " ", "\[Sigma]", " ", 
         RowBox[{"DawsonF", "[", 
          FractionBox["\[CapitalDelta]x", 
           RowBox[{"2", " ", "\[Sigma]"}]], "]"}]}], "+", 
        RowBox[{"\[CapitalDelta]x", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], "+", 
           RowBox[{
            SuperscriptBox["\[ExponentialE]", 
             RowBox[{
              SuperscriptBox["\[Sigma]", "2"], " ", 
              SuperscriptBox["\[CapitalOmega]", "2"]}]], " ", 
            SqrtBox["\[Pi]"], " ", "\[Sigma]", " ", "\[CapitalOmega]", " ", 
            RowBox[{"Erfc", "[", 
             RowBox[{"\[Sigma]", " ", "\[CapitalOmega]"}], "]"}]}]}], 
          ")"}]}]}], ")"}]}]}], "]"}]}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "Derived", " ", "in", " ", "previous", " ", "cells", " ", "using", " ", 
     RowBox[{"X", "~", "X"}]}], "+"}], "*)"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"neg2GaussianAnalytExpExact", "[", 
    RowBox[{"\[CapitalDelta]x_", ",", "\[CapitalOmega]_", ",", "\[Sigma]_"}], 
    "]"}], ":=", 
   RowBox[{"Max", "[", 
    RowBox[{"0", ",", 
     RowBox[{
      RowBox[{"Abs", "[", 
       RowBox[{"Xij", "[", 
        RowBox[{"\[CapitalDelta]x", ",", "\[CapitalOmega]"}], "]"}], "]"}], 
      "-", 
      RowBox[{"Pii", "[", "\[CapitalOmega]", "]"}]}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"neg2Detectors", "[", 
    RowBox[{"x_", ",", "\[CapitalOmega]_"}], "]"}], ":=", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"isGaussianSwitching", " ", "&&", " ", "isPointlikeDetectors"}], 
     ",", " ", 
     RowBox[{"neg2GaussianAnalytExpExact", "[", 
      RowBox[{"x", ",", "\[CapitalOmega]", ",", 
       RowBox[{"Rt1", "/", "\[Alpha]1"}]}], "]"}], ",", 
     RowBox[{"Max", "[", 
      RowBox[{"0", ",", 
       RowBox[{
        RowBox[{"Abs", "[", 
         RowBox[{"XijPlus", "[", 
          RowBox[{"x", ",", "\[CapitalOmega]"}], "]"}], "]"}], "-", 
        RowBox[{"Pii", "[", "\[CapitalOmega]", "]"}]}]}], "]"}]}], "]"}]}], 
  ";"}]}], "Input",
 InitializationCell->True,
